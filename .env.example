# Token del bot de Discord
DISCORD_TOKEN=pega_aqui_tu_token

# Prefijo de comandos
PREFIX=!

# Canal unico donde el bot procesa actividades
CHANNEL_ID_PARTICIPACION=123456789012345678

# Opcional: canal adicional donde se permiten #conteo y #lista
# Si lo dejas vacio, esos comandos funcionaran solo en el canal de participacion
CHANNEL_ID_CONTEO_ENCARGOS=

# Opcional: zona horaria usada para la ventana semanal de encargos
# Se deja Europe/Berlin para conservar el comportamiento del otro bot
REPORT_TIMEZONE=Europe/Berlin

# Opcional: maximo de mensajes a revisar al calcular #conteo y #lista
MAX_HISTORY_MESSAGES=1500

# IDs de admins autorizados para !reset-mensual (separados por coma)
ADMIN_USER_IDS=111111111111111111,222222222222222222

# Roles automáticos por progreso historico
ROLE_ID_INICIADO=333333333333333333
ROLE_ID_MIEMBRO=444444444444444444
ROLE_ID_AVENTURERO=555555555555555555
ROLE_ID_VANGUARDIA=666666666666666666
ROLE_ID_CAMPEON=777777777777777777
ROLE_ID_LEYENDA=888888888888888888

# Roles temporales Top 3 mensual
ROLE_ID_PALADIN_DEL_MES=999999999999999991
ROLE_ID_HEROE_DEL_MES=999999999999999992
ROLE_ID_GUERRERO_DEL_MES=999999999999999993

# Roles protegidos: el bot no tocara sus roles de progreso historico
# (separados por coma; puede quedar vacio)
PROTECTED_ROLE_IDS=123123123123123123,456456456456456456
